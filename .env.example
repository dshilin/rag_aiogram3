# Telegram Bot
BOT_TOKEN=your_telegram_bot_token

# LLM Settings
LLM_PROVIDER=yandex  # 'yandex', 'vsegpt', etc.
# Модель (оставьте пустым для модели по умолчанию). Указывайте только
# короткое имя модели (yandexgpt, yandexgpt-lite, ...); не вставляйте
# сюда URI вида "gpt://<folder>/<model>/latest" – это часто приводит к
# ошибке `invalid model_uri`.
LLM_MODEL=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=300

# OpenAI API (или другой LLM провайдер)
OPENAI_API_KEY=your_openai_api_key

# YandexGPT API
YANDEX_FOLDER_ID=your_yandex_folder_id
YANDEX_API_KEY=your_yandex_api_key  # IAM-токен (получается через API-ключ сервисного аккаунта)

# VseGPT.ru API
VSEGPT_API_KEY=your_vsegpt_api_key

# HuggingFace API (для доступа к моделям)
HF_TOKEN=your_huggingface_token

# RAG Settings
EMBEDDING_MODEL=sentence-transformers/rubert-base-cased
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3

# Database
EMBEDDINGS_DB_PATH=./data/embeddings

# Logging
# LOG_LEVEL=DEBUG  # Recommended for development - logs all user messages and call flow
# LOG_LEVEL=INFO   # Recommended for production - less verbose
LOG_LEVEL=DEBUG
