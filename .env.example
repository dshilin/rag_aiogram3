# Telegram Bot
BOT_TOKEN=your_telegram_bot_token

# OpenAI API (или другой LLM провайдер)
OPENAI_API_KEY=your_openai_api_key

# HuggingFace API (для доступа к моделям)
HF_TOKEN=your_huggingface_token

# RAG Settings
EMBEDDING_MODEL=sentence-transformers/rubert-base-cased
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3

# Database
EMBEDDINGS_DB_PATH=./data/embeddings

# Logging
LOG_LEVEL=INFO
